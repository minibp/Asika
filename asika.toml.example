# Asika Configuration
# See: https://github.com/minibp/asika for documentation

# Server settings
[server]
listen = ":8080"
mode   = "release"   # "debug" | "release"

# Mode: "multi" for cross-platform sync, "single" for single repo
mode = "multi"

# Database (bbolt)
[database]
path = "/var/lib/asika/asika.db"

# Authentication
[auth]
jwt_secret    = "change-me-in-production"
token_expiry  = "72h"

# Event source: "webhook" or "polling"
[events]
mode            = "webhook"
webhook_secret  = "change-me-webhook-secret"
polling_interval = "5m"   # only used when mode = "polling"

# Git work directory for temp bare repos
[git]
workdir = "/var/lib/asika/work"

# Platform tokens (or use env vars: ASIKA_GITHUB_TOKEN, etc.)
[tokens]
github = ""
gitlab = ""
gitea  = ""

# Merge queue defaults (overridable per repo group)
[merge_queue]
required_approvals = 1
ci_check_required  = true
core_contributors  = ["admin1", "admin2"]

# Spam detection
[spam]
enabled                    = true
time_window                = "10m"
threshold                  = 3
trigger_on_author          = true
trigger_on_similar_title   = true
title_similarity_threshold = 0.6
trigger_on_title_kw        = ["spam", "fix typo", "readme update"]

# Notification channels
[[notify]]
type   = "smtp"
config = { host = "smtp.example.com", port = 587, username = "bot@example.com", password = "change-me", to = ["admin@example.com"] }

# [[notify]]
# type   = "wecom"
# config = { webhook_url = "https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY" }

# [[notify]]
# type   = "github_at"
# config = { owner = "your-org", repo = "your-repo", to = ["admin1"] }

# [[notify]]
# type   = "gitlab_at"
# config = { owner = "your-org", repo = "your-repo", to = ["admin1"] }

# Label rules (hot-reloadable)
[[label_rules]]
pattern = "**/*.go"
label   = "go"

[[label_rules]]
pattern = "**/*.js"
label   = "javascript"

[[label_rules]]
pattern = "docs/**"
label   = "documentation"

# Repo groups (multi mode)
[[repo_groups]]
name           = "my-project"
mode           = "multi"         # overrides global mode per group
github         = "my-org/my-repo"
gitlab         = "my-org/my-repo"
gitea          = "my-org/my-repo"
default_branch = "main"
hookpath       = ""
ci_provider    = "github_actions"  # "github_actions" | "gitlab_ci" | "gitea_actions" | "none"

[repo_groups.merge_queue]
required_approvals = 2
ci_check_required  = true
core_contributors  = ["senior-dev1", "senior-dev2"]

# Single repo mode (only used when global mode = "single")
# [single_repo]
# platform       = "github"      # mirror_platform in tasks.md, the active platform
# repo           = "my-org/my-repo"
# default_branch = "main"
# hookpath       = ""
# ci_provider    = "github_actions"

# Custom hook path (global)
hookpath = ""